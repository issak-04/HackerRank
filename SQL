Select h.hacker_id, h.name From Hackers h Join (Select s.hacker_id, Count(Distinct s.challenge_id) full_count From Submissions s Join Challenges c On s.challenge_id = c.challenge_id Join Difficulty d On c.difficulty_level = d.difficulty_level Where s.score = d.score Group By s.hacker_id Having Count(Distinct s.challenge_id) > 1) x On h.hacker_id = x.hacker_id Order By x.full_count Desc, h.hacker_id Asc;

