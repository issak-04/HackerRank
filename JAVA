import java.util.*;

public class Solution {

    public static boolean canWin(int leap, int[] game) {
        boolean[] visited = new boolean[game.length];
        return canReach(0, leap, game, visited);
    }

    private static boolean canReach(int i, int leap, int[] game, boolean[] visited) {
        // If we reach or go past the end, we win
        if (i >= game.length) return true;

        // Invalid position
        if (i < 0 || game[i] == 1 || visited[i]) return false;

        // Mark this index as visited
        visited[i] = true;

        // Try all possible moves
        return canReach(i + leap, leap, game, visited) ||
               canReach(i + 1, leap, game, visited) ||
               canReach(i - 1, leap, game, visited);
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        int q = scan.nextInt();

        while (q-- > 0) {
            int n = scan.nextInt();
            int leap = scan.nextInt();

            int[] game = new int[n];
            for (int i = 0; i < n; i++) {
                game[i] = scan.nextInt();
            }

            System.out.println(canWin(leap, game) ? "YES" : "NO");
        }

        scan.close();
    }
}

